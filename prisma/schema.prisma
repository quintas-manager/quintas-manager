generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OPERATOR
}

enum TipoTemporada {
  ALTA
  BAJA
}

enum TipoAlquiler {
  DIA
  FIN_DE_SEMANA
  SEMANA
  QUINCENA
  MES
}

enum EstadoReserva {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum GastoPagador {
  CAJA
  GRACIELA
  MATIAS
  ROCIO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  MERCADOPAGO
}

model User {
  id          String               @id @default(cuid())
  name        String
  email       String               @unique
  password    String
  role        Role                 @default(OPERATOR)
  createdAt   DateTime             @default(now())
  reservas    Reserva[]
  gastos      Gasto[]
  pagos       Pago[]
  cierresMes  CierreMes[]
  cronogramas CronogramaLimpieza[]
}

model Quinta {
  id                String            @id @default(cuid())
  nombre            String
  descripcion       String?
  capacidadAdultos  Int
  capacidadNinos    Int               @default(0)
  colorHex          String            @default("#3b82f6")
  activa            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  reservas          Reserva[]
  temporadas        TemporadaQuinta[]
  precios           PrecioTemporada[]
  gastos            Gasto[]
  cierresMes        CierreMes[]
}

model Cliente {
  id              String    @id @default(cuid())
  nombre          String
  apellido        String
  telefono        String
  email           String?
  dni             String?
  notas           String?
  fechaCumpleanos DateTime?
  createdAt       DateTime  @default(now())
  reservas        Reserva[]
}

model Temporada {
  id           String            @id @default(cuid())
  nombre       String
  tipo         TipoTemporada
  fechaInicio  DateTime
  fechaFin     DateTime
  quintas      TemporadaQuinta[]
  precios      PrecioTemporada[]
}

model TemporadaQuinta {
  temporadaId String
  quintaId    String
  temporada   Temporada @relation(fields: [temporadaId], references: [id], onDelete: Cascade)
  quinta      Quinta    @relation(fields: [quintaId], references: [id], onDelete: Cascade)

  @@id([temporadaId, quintaId])
}

model Reserva {
  id             String        @id @default(cuid())
  quintaId       String
  clienteId      String
  creadoPorId    String
  fechaInicio    DateTime
  fechaFin       DateTime
  tipoAlquiler   TipoAlquiler
  estado         EstadoReserva @default(PENDIENTE)
  montoTotal     Decimal       @db.Decimal(10, 2)
  sena           Decimal?      @db.Decimal(10, 2)  @map("seña")
  notas           String?
  motivoEvento    String?
  tieneMascota    Boolean       @default(false)
  cantidadPersonas Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  quinta          Quinta        @relation(fields: [quintaId], references: [id])
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  creadoPor       User          @relation(fields: [creadoPorId], references: [id])
  pagos           Pago[]
}

model PrecioTemporada {
  id           String       @id @default(cuid())
  quintaId     String
  temporadaId  String
  tipoAlquiler TipoAlquiler
  precio       Decimal      @db.Decimal(10, 2)
  quinta       Quinta       @relation(fields: [quintaId], references: [id], onDelete: Cascade)
  temporada    Temporada    @relation(fields: [temporadaId], references: [id], onDelete: Cascade)

  @@unique([quintaId, temporadaId, tipoAlquiler])
}

model CategoriaGasto {
  id     String  @id @default(cuid())
  nombre String  @unique
  activa Boolean @default(true)
  gastos Gasto[]
}

model Gasto {
  id              String        @id @default(cuid())
  quintaId        String
  categoriaId     String
  creadoPorId     String
  descripcion     String
  monto           Decimal       @db.Decimal(10, 2)
  fecha           DateTime
  pagadoPor       GastoPagador
  reintegrado     Boolean       @default(false)
  fechaReintegro  DateTime?
  comprobante     String?
  notas           String?
  createdAt       DateTime      @default(now())
  quinta          Quinta        @relation(fields: [quintaId], references: [id])
  categoria       CategoriaGasto @relation(fields: [categoriaId], references: [id])
  creadoPor       User          @relation(fields: [creadoPorId], references: [id])
}

model Pago {
  id          String     @id @default(cuid())
  reservaId   String
  creadoPorId String
  monto       Decimal    @db.Decimal(10, 2)
  fecha       DateTime
  metodoPago  MetodoPago
  notas       String?
  createdAt   DateTime   @default(now())
  reserva     Reserva    @relation(fields: [reservaId], references: [id])
  creadoPor   User       @relation(fields: [creadoPorId], references: [id])
}

model CierreMes {
  id                   String   @id @default(cuid())
  quintaId             String
  mes                  Int
  anio                 Int
  totalIngresos        Decimal  @db.Decimal(10, 2)
  totalGastos          Decimal  @db.Decimal(10, 2)
  resultado            Decimal  @db.Decimal(10, 2)
  parteGraciela        Decimal  @db.Decimal(10, 2)
  parteMatias          Decimal  @db.Decimal(10, 2)
  reintegrosGraciela   Decimal  @db.Decimal(10, 2)
  reintegrosMatias     Decimal  @db.Decimal(10, 2)
  cobrarGraciela       Decimal  @db.Decimal(10, 2)
  cobrarMatias         Decimal  @db.Decimal(10, 2)
  cerradoPorId         String
  fechaCierre          DateTime
  createdAt            DateTime @default(now())
  quinta               Quinta   @relation(fields: [quintaId], references: [id])
  cerradoPor           User     @relation(fields: [cerradoPorId], references: [id])

  @@unique([quintaId, mes, anio])
}

model LugarLimpieza {
  id             String          @id @default(cuid())
  nombre         String
  activo         Boolean         @default(true)
  orden          Int
  diasPrincipal  DiaCronograma[] @relation("LugarPrincipal")
  diasSecundario DiaCronograma[] @relation("LugarSecundario")
}

model CronogramaLimpieza {
  id           String          @id @default(cuid())
  semanaInicio DateTime
  creadoPorId  String
  enviado      Boolean         @default(false)
  fechaEnvio   DateTime?
  createdAt    DateTime        @default(now())
  creadoPor    User            @relation(fields: [creadoPorId], references: [id])
  dias         DiaCronograma[]
}

model DiaCronograma {
  id                String              @id @default(cuid())
  cronogramaId      String
  diaSemana         Int
  lugarPrincipalId  String
  lugarSecundarioId String?
  cronograma        CronogramaLimpieza  @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  lugarPrincipal    LugarLimpieza       @relation("LugarPrincipal", fields: [lugarPrincipalId], references: [id])
  lugarSecundario   LugarLimpieza?      @relation("LugarSecundario", fields: [lugarSecundarioId], references: [id])
}

model ConfiguracionApp {
  id    String @id @default(cuid())
  clave String @unique
  valor String
}
